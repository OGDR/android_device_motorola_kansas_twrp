						regulator-enable-ramp-delay = <0x2a8>;
						regulator-allowed-modes = <0x00 0x02>;
						phandle = <0x1b>;
					};

					mt6377_vmch_eint_low: vmch-eint-low {
						regulator-compatible = "VMCH_EINT_LOW";
						regulator-name = "mt6377_vmch_eint_low";
						regulator-min-microvolt = <0x2dc6c0>;
						regulator-max-microvolt = <0x325aa0>;
						regulator-enable-ramp-delay = <0x2a8>;
						regulator-allowed-modes = <0x00 0x02>;
						phandle = <0x46>;
					};
				};

				mt6377_lbat: lbat-service {
					compatible = "mediatek,mt6377-lbat-service";
					phandle = <0x92>;
				};

				mt6377_rtc: mt6377_rtc {
					status = "okay";
					compatible = "mediatek,mt6377-rtc";
					base = <0x580>;
					#address-cells = <0x01>;
					#size-cells = <0x01>;
					phandle = <0x93>;

					fg_init: fg_init {
						reg = <0x00 0x01>;
						phandle = <0x05>;
					};

					fg_soc: fg_soc {
						reg = <0x01 0x01>;
						phandle = <0x06>;
					};

					ext_32k: ext_32k {
						reg = <0x02 0x01>;
						bits = <0x06 0x01>;
						phandle = <0x94>;
					};
				};
			};
		};
	};

	fragment@1 {
		target = <&mmc0>;

		__overlay__ {
			host-index = <0x00>;
			status = "disabled";
			pinctrl-names = "default", "state_uhs";
			pinctrl-0 = <&mmc0_pins_default>;
			pinctrl-1 = <&mmc0_pins_uhs>;
			bus-width = <0x08>;
			max-frequency = <0xbebc200>;
			ocr-voltage = <0x30000>;
			cap-mmc-highspeed;
			mmc-ddr-1_8v;
			mmc-hs200-1_8v;
			mmc-hs400-1_8v;
			hs400-ds-delay = <0x12818>;
			read-dat-cnt-hs400 = <0x03>;
			no-sdio;
			no-sd;
			non-removable;
			supports-cqe;
			dvfsrc-vcore-supply = <&dvfsrc_vcore>;
			req-vcore = <0x9eb10>;
			cap-mmc-hw-reset;
		};
	};

	fragment@2 {
		target = <&mmc1>;

		__overlay__ {
			host-index = <0x01>;
			status = "okay";
			pinctrl-names = "default", "state_uhs";
			pinctrl-0 = <&mmc1_pins_default>;
			pinctrl-1 = <&mmc1_pins_uhs>;
			bus-width = <0x04>;
			max-frequency = <0xbebc200>;
			ocr-voltage = <0x30000>;
			cap-sd-highspeed;
			sd-uhs-sdr12;
			sd-uhs-sdr25;
			sd-uhs-sdr50;
			sd-uhs-sdr104;
			sd-uhs-ddr50;
			cd-debounce-delay-ms = <0x00>;
			cd-gpios = <&pio>, <0x0e 0x01>;
			no-mmc;
			no-sdio;
			dvfsrc-vcore-supply = <&dvfsrc_vcore>;
			req-vcore = <0x9eb10>;
			mediatek,mmc-qos;
			interconnects = <&dvfsrc>, <0x15>, <&dvfsrc>, <0x00>;
			interconnect-names = "msdc-perf-bw";
			required-opps = <&dvfsrc_freq_opp4>;
		};
	};

	fragment@3 {
		target = <&pio>;

		__overlay__ {

			mmc0_pins_default: mmc0default {
				phandle = <0x07>;

				pins_cmd_dat {
					pinmux = <0xb901 0xba01 0xbb01 0xbc01 0xbd01 0xbe01 0xbf01 0xc001 0xb701>;
					input-enable;
					drive-strength = <0x04>;
					bias-pull-up = <0x65>;
				};

				pins_clk {
					pinmux = <0xb601>;
					drive-strength = <0x04>;
					bias-pull-down = <0x66>;
				};

				pins_rst {
					pinmux = <0xb801>;
					drive-strength = <0x04>;
					bias-pull-up = <0x64>;
				};
			};

			mmc0_pins_uhs: mmc0@0 {
				phandle = <0x08>;

				pins_cmd_dat {
					pinmux = <0xb901 0xba01 0xbb01 0xbc01 0xbd01 0xbe01 0xbf01 0xc001 0xb701>;
					input-enable;
					drive-strength = <0x04>;
					bias-pull-up = <0x65>;
				};

				pins_clk {
					pinmux = <0xb601>;
					drive-strength = <0x04>;
					bias-pull-down = <0x66>;
				};

				pins_ds {
					pinmux = <0xb501>;
					drive-strength = <0x04>;
					bias-pull-down = <0x66>;
				};

				pins_rst {
					pinmux = <0xb801>;
					drive-strength = <0x04>;
					bias-pull-up = <0x64>;
				};
			};

			mmc1_pins_default: mmc1default {
				phandle = <0x09>;

				pins_cmd_dat {
					pinmux = <0x4b01 0x4c01 0x4d01 0x4e01 0x4a01>;
					input-enable;
					drive-strength = <0x03>;
					bias-pull-up = <0x65>;
				};

				pins_clk {
					pinmux = <0x4901>;
					drive-strength = <0x07>;
					bias-pull-down = <0x66>;
				};
			};

			mmc1_pins_uhs: mmc1@0 {
				phandle = <0x0a>;

				pins_cmd_dat {
					pinmux = <0x4b01 0x4c01 0x4d01 0x4e01 0x4a01>;
					input-enable;
					drive-strength = <0x03>;
					bias-pull-up = <0x65>;
				};

				pins_clk {
					pinmux = <0x4901>;
					drive-strength = <0x07>;
					bias-pull-down = <0x66>;
				};
			};
		};
	};

	fragment@4 {
		target = <&tboard_thermistor1>;

		__overlay__ {
			reg = <0x00 0x1c023528 0x00 0x04>;
		};
	};

	fragment@5 {
		target = <&tboard_thermistor2>;

		__overlay__ {
			reg = <0x00 0x1c023520 0x00 0x04>;
		};
	};

	fragment@6 {
		target = <&tboard_thermistor3>;

		__overlay__ {
			reg = <0x00 0x1c02351c 0x00 0x04>;
		};
	};

	fragment@7 {
		target = <&tsx_thermistor>;

		__overlay__ {
			reg = <0x00 0x1c023530 0x00 0x04>;
		};
	};

	fragment@8 {
		target = <&spmi>;

		__overlay__ {

			pmic@4 {

				mt6377_dynamic_loading_throttling: mtk_dynamic_loading_throttling {
					compatible = "mediatek,mt6377-dynamic_loading_throttling";
					mediatek,charger = <&lk_charger>;
					uvlo-level = <0xa28>;
					io-channels = <&pmic_adc>, <0x0f>, <&pmic_adc>, <0x10>, <&pmic_adc>, <0x00>, <&pmic_adc>, <0x02>;
					io-channel-names = "pmic_ptim", "pmic_imix_r", "pmic_batadc", "pmic_vbus";
					bootmode = <&chosen>;
					phandle = <0x1e>;
				};

				mt6377_batoc_throttle: mtk_battery_oc_throttling {
					compatible = "mediatek,mt6377-battery_oc_throttling";
					oc-thd-h = <0x1a90>;
					oc-thd-l = <0x1f40>;
					phandle = <0x95>;
				};
			};

			mt6319_3: mt6319@3 {
				compatible = "mediatek,mt6319";
				reg = <0x03 0x00>;
				phandle = <0x96>;

				extbuck-debug {
					compatible = "mediatek,spmi-pmic-debug";
				};

				mt6319_3_regulator: mt6319-3-regulator {
					compatible = "mediatek,mt6315_3-regulator";
					buck-size = <0x03>;
					buck1-modeset-mask = <0x03>;
					phandle = <0x97>;

					mt6319_3_vbuck1: 3-vbuck1 {
						regulator-compatible = "vbuck1";
						regulator-name = "3_vbuck1";
						regulator-min-microvolt = <0x493e0>;
						regulator-max-microvolt = <0x123716>;
						regulator-enable-ramp-delay = <0x100>;
						regulator-allowed-modes = <0x00 0x01 0x02>;
						regulator-always-on;
						phandle = <0x13>;
					};

					mt6319_3_vbuck3: 3-vbuck3 {
						regulator-compatible = "vbuck3";
						regulator-name = "3_vbuck3";
						regulator-min-microvolt = <0x493e0>;
						regulator-max-microvolt = <0x123716>;
						regulator-enable-ramp-delay = <0x100>;
						regulator-allowed-modes = <0x00 0x01 0x02>;
						phandle = <0x0d>;
					};

					mt6319_3_vbuck4: 3-vbuck4 {
						regulator-compatible = "vbuck4";
						regulator-name = "3_vbuck4";
						regulator-min-microvolt = <0x493e0>;
						regulator-max-microvolt = <0x123716>;
						regulator-enable-ramp-delay = <0x100>;
						regulator-allowed-modes = <0x00 0x01 0x02>;
						regulator-always-on;
						phandle = <0x14>;
					};
				};
			};
		};
	};

	fragment@9 {
		target = <&mt6377_temp>;

		__overlay__ {
			io-channels = <&pmic_adc>, <0x05>, <&pmic_adc>, <0x06>, <&pmic_adc>, <0x07>, <&pmic_adc>, <0x08>;
			io-channel-names = "pmic6377_ts1", "pmic6377_ts2", "pmic6377_ts3", "pmic6377_ts4";
