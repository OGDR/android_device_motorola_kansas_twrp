				novatek,supported_gesture_type = <0x06>;
			};

			focaltech@1 {
				compatible = "focaltech,fts";
				reg = <0x01>;
				status = "ok";
				spi-max-frequency = <0x927c00>;
				focaltech,reset-gpio = <&pio>, <0x93 0x00>;
				focaltech,irq-gpio = <&pio>, <0x04 0x00>;
				focaltech,max-touch-number = <0x0a>;
				focaltech,display-coords = <0x00 0x00 0x2d0 0x644>;
				focaltech,report_gesture_key = <0x3b>;
				focaltech,supported_gesture_type = <0x06>;
				focaltech,panel-supplier = "boe_ft8057s", "boe_ft8057m";
				focaltech,touch-charger-detect-psy-name = "battery";
				focaltech,touch-charger-detect-psp = "POWER_SUPPLY_PROP_STATUS";
