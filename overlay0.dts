			pinctrl-5 = <&ctp_nt36528_spi_mode>;

			novatek@0 {
				compatible = "novatek,NVT-ts-spi";
				reg = <0x00>;
				status = "ok";
				spi-max-frequency = <0x927c00>;
				novatek,reset-gpio = <&pio>, <0x93 0x00>;
				novatek,irq-gpio = <&pio>, <0x04 0x01>;
				novatek,def-max-resolution = <0x2d0 0x644>;
				novatek,panel-supplier = "nt36528a", "nt36528";
				novatek,gesture-wait-pm;
				novatek,usb_charger;
				novatek,psy-name = "battery";
