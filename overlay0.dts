	fragment@95 {
		target = <&thermal_zones>;

		__overlay__ {

			quiet_ntc: quiet_ntc {
				polling-delay = <0x00>;
				polling-delay-passive = <0x00>;
				thermal-sensors = <&tboard_thermistor9>;
				phandle = <0xab>;
			};

			chg_ntc: chg_ntc {
				polling-delay = <0x00>;
				polling-delay-passive = <0x00>;
				thermal-sensors = <&tboard_thermistor8>;
				phandle = <0xac>;
			};

			tspk_ntc: tspk_ntc {
				polling-delay = <0x00>;
				polling-delay-passive = <0x00>;
				thermal-sensors = <&tboard_thermistor7>;
				phandle = <0xad>;
			};

			cam_ntc: cam_ntc {
				polling-delay = <0x00>;
				polling-delay-passive = <0x00>;
				thermal-sensors = <&tboard_thermistor6>;
				phandle = <0xae>;
			};

			pa_therm1: pa_therm1 {
				polling-delay = <0x00>;
				polling-delay-passive = <0x00>;
				thermal-sensors = <&tboard_thermistor5>;
				phandle = <0xaf>;
			};
		};
	};

	switch_chg_eint: switch_chg_eint {
		interrupt-parent = <&pio>;
		interrupts = <0x03 0x01>;
		status = "okay";
		phandle = <0xb0>;
	};

	tcpc_pd: tcpc_pd {
		interrupt-parent = <&pio>;
		interrupts = <0x08 0x01>;
		status = "okay";
		phandle = <0xb1>;
	};

	eint_cp: eint_cp {
		interrupt-parent = <&pio>;
		interrupts = <0x05 0x01>;
		status = "okay";
		phandle = <0xb2>;
	};

	fragment@96 {
		target = <&i2c3>;

		__overlay__ {
			clock-frequency = <0x61a80>;

			sn220e: sn220e@28 {
				compatible = "qcom,sn-nci";
				reg = <0x28>;
				qcom,sn-irq = <&pio>, <0x29 0x00>;
				qcom,sn-ven = <&pio>, <0x2a 0x00>;
				status = "okay";
				phandle = <0xb3>;
			};
		};
	};

	fragment@97 {
		target = <&u2port0>;

		__overlay__ {
			mediatek,eye-vrt = <0x06>;
			mediatek,eye-vrt-host = <0x06>;
		};
	};

	fragment@98 {
		target = <&swtp>;

		__overlay__ {
			interrupt-parent = <&pio>;
			interrupts = <0x06 0x04 0x06 0x00>;
			deb-gpios = <&pio>, <0x06 0x00>;
			debounce = <0x200>;
			status = "okay";
		};
	};

