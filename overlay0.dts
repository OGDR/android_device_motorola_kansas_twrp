		target = <&thermal_zones>;

		__overlay__ {

			pmic6377_vs1 {
				polling-delay = <0x00>;
				polling-delay-passive = <0x00>;
				thermal-sensors = <&mt6377_temp>, <0x00>;
			};

			pmic6377_vbuck2 {
				polling-delay = <0x00>;
				polling-delay-passive = <0x00>;
				thermal-sensors = <&mt6377_temp>, <0x01>;
			};

			pmic6377_vemc {
				polling-delay = <0x00>;
				polling-delay-passive = <0x00>;
				thermal-sensors = <&mt6377_temp>, <0x02>;
			};

			pmic6377_vmch {
				polling-delay = <0x00>;
				polling-delay-passive = <0x00>;
				thermal-sensors = <&mt6377_temp>, <0x03>;
			};

			ap_ntc: ap_ntc {
				polling-delay = <0x00>;
				polling-delay-passive = <0x00>;
				thermal-sensors = <&tboard_thermistor1>;
				phandle = <0x98>;
			};

			ltepa_ntc: ltepa_ntc {
				polling-delay = <0x00>;
				polling-delay-passive = <0x00>;
				thermal-sensors = <&tboard_thermistor2>;
				phandle = <0x99>;
