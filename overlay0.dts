	fragment@64 {
		target = <&pio>;

		__overlay__ {

			ctp_nt36528_pins_default: pins-default {
				phandle = <0x39>;
			};

			ctp_nt36528_int_active: int1-active {
				phandle = <0x3a>;

				pins-cmd-dat {
					pinmux = <0x400>;
					input-enable;
				};
			};

			ctp_nt36528_reset_active: reset1-active {
				phandle = <0x3b>;

				pins-cmd-dat {
					pinmux = <0x9300>;
					output-high;
				};
			};

			ctp_nt36528_int_suspend: int1-suspend {
				phandle = <0x3c>;

				pins-cmd-dat {
					pinmux = <0x400>;
					output-low;
				};
			};

			ctp_nt36528_reset_suspend: reset1-suspend {
				phandle = <0x3d>;

				pins-cmd-dat {
					pinmux = <0x9300>;
					output-low;
				};
			};

			ctp_nt36528_spi_mode: spimode-default {
				phandle = <0x3e>;

				pins-cmd-dat {
					pinmux = <0x4402 0x4502 0x4602 0x4702>;
				};
			};
		};
	};

	fragment@65 {
