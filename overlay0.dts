	fragment@63 {
		target = <&spi3>;

		__overlay__ {
			status = "okay";
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			mediatek,pad-select = <0x00 0x01>;
			pinctrl-names = "default", "nt36528_int_active", "nt36528_reset_active", "nt36528_int_suspend", "nt36528_reset_suspend", "nt36528_spi_mode";
			pinctrl-0 = <&ctp_nt36528_pins_default>;
