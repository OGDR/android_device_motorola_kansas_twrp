	fragment@40 {
		target = <&mtk_leds>;

		__overlay__ {
			compatible = "mediatek,i2c-leds";

			backlight {
				led_mode = <0x06>;
				gate_enable = <0x01>;
				pwm_config = <0x00 0x01 0x00 0x00 0x00>;
