	fragment@44 {
		target = <&pio>;

		__overlay__ {

			sel_up: sel_high {
				phandle = <0x24>;

				pins_cmd_dat {
					pinmux = <0x3600>;
					output-high;
				};
			};

			sel_down: sel_low {
				phandle = <0x25>;

				pins_cmd_dat {
					pinmux = <0x3600>;
					output-low;
				};
			};

			sw_enable: sw_enable {
				phandle = <0x26>;

				pins_cmd_dat {
					pinmux = <0x1e00>;
					output-high;
				};
			};

			sw_disable: sw_disable {
				phandle = <0x27>;

				pins_cmd_dat {
					pinmux = <0x1e00>;
					output-high;
				};
			};

			ps_enable: ps_enable {
				phandle = <0x22>;

				pins_cmd_dat {
					pinmux = <0x8d00>;
					output-low;
				};
			};

			ps_disable: ps_disable {
				phandle = <0x23>;

				pins_cmd_dat {
					pinmux = <0x8d00>;
					output-low;
				};
			};
		};
	};

