	fragment@41 {
		target = <&pio>;

		__overlay__ {

			mtkfb_pins_lcm_led_en1: lcm_led_en1_gpio {
				phandle = <0x1f>;

				pins_cmd_dat {
					pinmux = <0x9600>;
					slew-rate = <0x01>;
					output-high;
				};
			};

			mtkfb_pins_lcm_led_en0: lcm_led_en0_gpio {
				phandle = <0x20>;

				pins_cmd_dat {
					pinmux = <0x9600>;
					slew-rate = <0x01>;
					output-low;
				};
			};

			mtkfb_pins_lcm_cphy_out_gpio: lcm_cphy_out_gpio {
				phandle = <0x21>;

				pins_cmd_dat {
					pinmux = <0x8500>;
					slew-rate = <0x01>;
					output-high;
				};
