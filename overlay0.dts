			status = "okay";
			clock-frequency = <0x61a80>;

			strobe_main: strobe_main@63 {
				compatible = "mediatek,strobe_main";
				reg = <0x63>;
				#cooling-cells = <0x02>;
				pinctrl-names = "default", "hwen-high", "hwen-low";
				pinctrl-0 = <&flashlight_pins_default>;
				pinctrl-1 = <&flashlight_pins_hwen_high>;
				pinctrl-2 = <&flashlight_pins_hwen_low>;
				status = "okay";
				decouple = <0x01>;
				phandle = <0xb6>;

				flash@0 {
					reg = <0x00>;
					type = <0x00>;
					ct = <0x00>;
					part = <0x00>;

