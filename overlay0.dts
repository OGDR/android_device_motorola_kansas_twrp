/dts-v1/;
/plugin/;

/ {

	fragment@0 {
		target = <&spmi>;

		__overlay__ {

			main_pmic: pmic@4 {
				compatible = "mediatek,mt6377";
				reg = <0x04 0x00>;
				interrupts = <0x04>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				interrupt-controller;
				#interrupt-cells = <0x02>;
				phandle = <0x12>;

				mtk-spmi-pmic-debug {
					compatible = "mediatek,spmi-pmic-debug";
				};

				accdet: accdet {
					compatible = "mediatek,mt6377-accdet";
					accdet-name = "mt63xx-accdet";
					accdet-mic-vol = <0x07>;
					accdet-plugout-debounce = <0x01>;
					accdet-mic-mode = <0x01>;
					eint_use_ext_res = <0x00>;
					headset-mode-setting = <0x500 0x500 0x01 0x1f0 0x800 0x800 0x20 0x44 0x04 0x01 0x05 0x03 0x03 0x05 0x0e>;
					headset-use-ap-eint = <0x00>;
					headset-eint-num = <0x00>;
					headset-eint-trig-mode = <0x01>;
					headset-key-mode = <0x00>;
					headset-three-key-threshold = <0x00 0x50 0xdc 0x190>;
					headset-three-key-threshold-CDD = <0x00 0x79 0xc0 0x258>;
					headset-four-key-threshold = <0x00 0x3a 0x79 0xc0 0x190>;
					io-channels = <&pmic_adc>, <0x09>;
					io-channel-names = "pmic_accdet";
					nvmem = <&mt6377_efuse>;
					nvmem-names = "mt63xx-accdet-efuse";
					status = "okay";
					phandle = <0x77>;
				};

				pmic_adc: mt6377-auxadc {
					compatible = "mediatek,pmic-auxadc", "mediatek,mt6377-auxadc";
					#io-channel-cells = <0x01>;
					isink_load-supply = <&mt6377_isink_load>;
					phandle = <0x01>;

					batadc {
						channel = <0x00>;
						resistance-ratio = <0x07 0x02>;
						avg-num = <0x80>;
					};

					vcdt {
						channel = <0x02>;
					};

					bat-temp {
						channel = <0x03>;
						resistance-ratio = <0x05 0x02>;
					};

					chip-temp {
						channel = <0x05>;
					};

					vcore-temp {
						channel = <0x06>;
					};

					vproc-temp {
						channel = <0x07>;
					};

					vgpu-temp {
						channel = <0x08>;
					};

					accdet {
						channel = <0x09>;
					};

					hpofs-cal {
						channel = <0x0c>;
						avg-num = <0x100>;
					};

					vbif {
						channel = <0x0e>;
						resistance-ratio = <0x05 0x02>;
					};

					imp {
						channel = <0x0f>;
						resistance-ratio = <0x07 0x02>;
						avg-num = <0x80>;
					};

					imix_r {
						channel = <0x10>;
					};
				};

				mt6377_clock_buffer: mt6377_clock_buffer {
					compatible = "mediatek,clock_buffer";
					mediatek,xo-mode-num = <0x03>;
					mediatek,xo-buf-allow-control = <0x00 0x01 0x01 0x01 0x00 0x00 0x01>;
					mediatek,xo-buf-name = "XO_SOC", "XO_WCN", "XO_NFC", "XO_CEL", "RSV1", "RSV2", "XO_EXT";
					mediatek,dcxo-de-sense-support;
					mediatek,dcxo-impedance-support;
					mediatek,xo-buf-support = <0x01 0x01 0x01 0x01 0x01 0x01 0x01>;
					mediatek,xo-voter-support;
					mediatek,dcxo-spmi-rw;
					mediatek,pmrc-en-support;
					clkbuf_ctl = <&clock_buffer_ctrl>;
					mediatek,enable;
					phandle = <0x78>;
				};

				mt6377-consys {
					compatible = "mediatek,mt6377-consys";
				};

				mt6377codec: mt6377codec {
					compatible = "mediatek,mt6377-sound";
					mediatek,dmic-mode = <0x00>;
					mediatek,mic-type = <0x01 0x01 0x01>;
					io-channels = <&pmic_adc>, <0x0c>;
					io-channel-names = "pmic_hpofs_cal";
					nvmem = <&mt6377_efuse>;
					nvmem-names = "pmic-hp-efuse";
					reg-vaud28-supply = <&mt6377_vaud28>;
					phandle = <0x79>;
				};

				mt6377_efuse: mt6377-efuse {
					compatible = "mediatek,mt6377-efuse";
					#address-cells = <0x01>;
					#size-cells = <0x01>;
					phandle = <0x02>;

					mt6377_thermal_efuse: mt6377_e_data {
						reg = <0x60 0x0a>;
						phandle = <0x0b>;
					};
				};

				mt6377keys: mt6377keys {
					compatible = "mediatek,mt6377-keys";
					mediatek,long-press-mode = <0x01>;
					power-off-time-sec = <0x00>;
					phandle = <0x7a>;

					power {
						linux,keycodes = <0x74>;
						wakeup-source;
					};

					home {
						linux,keycodes = <0x72>;
					};
				};

				mtk_gauge: mtk_gauge {
					compatible = "mediatek,mt6377-gauge";
					bootmode = <&chosen>;
					io-channels = <&pmic_adc>, <0x03>, <&pmic_adc>, <0x00>, <&pmic_adc>, <0x0e>, <&pmic_adc>, <0x0f>, <&pmic_adc>, <0x10>;
					io-channel-names = "pmic_battery_temp", "pmic_battery_voltage", "pmic_bif_voltage", "pmic_ptim_voltage", "pmic_ptim_r";
					nvmem-cells = <&fg_init>, <&fg_soc>;
					nvmem-cell-names = "initialization", "state-of-charge";
					charger = <&mt6375_chg>;
					DIFFERENCE_FULLOCV_ITH = <0x50>;
					SHUTDOWN_1_TIME = <0x1e>;
					KEEP_100_PERCENT = <0x01>;
					CURR_MEASURE_20A = <0x00>;
					UNIT_MULTIPLE = <0x01>;
					R_FG_VALUE = <0x05>;
					EMBEDDED_SEL = <0x01>;
					PMIC_SHUTDOWN_CURRENT = <0x14>;
					FG_METER_RESISTANCE = <0x46>;
					CAR_TUNE_VALUE = <0x65>;
					PMIC_MIN_VOL = <0x82dc>;
					POWERON_SYSTEM_IBOOT = <0x1f4>;
					SHUTDOWN_GAUGE0_VOLTAGE = <0x84d0>;
					TEMPERATURE_T0 = <0x32>;
					TEMPERATURE_T1 = <0x19>;
					TEMPERATURE_T2 = <0x0a>;
					TEMPERATURE_T3 = <0x00>;
					TEMPERATURE_T4 = <0xfffffffa>;
					TEMPERATURE_T5 = <0xfffffff6>;
					g_FG_PSEUDO100_T0 = <0x64>;
					g_FG_PSEUDO100_T1 = <0x64>;
					g_FG_PSEUDO100_T2 = <0x64>;
					g_FG_PSEUDO100_T3 = <0x64>;
					g_FG_PSEUDO100_T4 = <0x64>;
					Q_MAX_SYS_VOLTAGE_BAT0 = <0xd16>;
					Q_MAX_SYS_VOLTAGE_BAT1 = <0xd16>;
					Q_MAX_SYS_VOLTAGE_BAT2 = <0xd16>;
					Q_MAX_SYS_VOLTAGE_BAT3 = <0xd16>;
					COM_FG_METER_RESISTANCE = <0x46>;
					COM_R_FG_VALUE = <0x00>;
					enable_tmp_intr_suspend = <0x00>;
					ACTIVE_TABLE = <0x05>;
					MULTI_TEMP_GAUGE0 = <0x01>;
					RBAT_PULL_UP_VOLT = <0xa8c>;
					battery0_profile_t0_num = <0x64>;
					battery0_profile_t0_col = <0x04>;
					battery0_profile_t0 = <0x00 0xae6a 0x2bc 0x299 0x1f0 0xaddd 0x2bc 0x299 0x3e0 0xad61 0x2d4 0x2b0 0x5d0 0xacf3 0x2bc 0x299 0x7bf 0xac96 0x2bc 0x299 0x9af 0xac3c 0x2bf 0x29c 0xb9f 0xabea 0x2d5 0x2b1 0xd8f 0xab8c 0x2d1 0x2ad 0xf7f 0xab26 0x2bc 0x299 0x116f 0xaac1 0x2c1 0x29e 0x135f 0xaa64 0x2d5 0x2b1 0x154e 0xa9fc 0x2d0 0x2ac 0x173e 0xa98d 0x2c2 0x29f 0x192e 0xa925 0x2d5 0x2b1 0x1b1e 0xa8b4 0x2d5 0x2b1 0x1d0e 0xa842 0x2cd 0x2a9 0x1efe 0xa7cb 0x2c4 0x2a1 0x20ee 0xa756 0x2cc 0x2a8 0x22dd 0xa6e0 0x2c5 0x2a2 0x24cd 0xa66b 0x2d5 0x2b1 0x26bd 0xa5f2 0x2d5 0x2b1 0x28ad 0xa577 0x2d5 0x2b1 0x2a9d 0xa4fc 0x2d5 0x2b1 0x2c8d 0xa482 0x2d5 0x2b1 0x2e7d 0xa407 0x2d5 0x2b1 0x306c 0xa38e 0x2d5 0x2b1 0x325c 0xa313 0x2d5 0x2b1 0x344c 0xa298 0x2d5 0x2b1 0x363c 0xa223 0x2e3 0x2be 0x382c 0xa1ad 0x2df 0x2ba 0x3a1c 0xa13a 0x2e4 0x2bf 0x3c0c 0xa0c9 0x2ee 0x2c9 0x3dfb 0xa059 0x2ee 0x2c9 0x3feb 0x9fe8 0x2ee 0x2c9 0x41db 0x9f7f 0x2ff 0x2d9 0x43cb 0x9f13 0x307 0x2e0 0x45bb 0x9ea9 0x307 0x2e0 0x47ab 0x9e43 0x307 0x2e0 0x499b 0x9ddc 0x31a 0x2f2 0x4b8a 0x9d77 0x320 0x2f8 0x4d7a 0x9d12 0x320 0x2f8 0x4f6a 0x9cb3 0x34a 0x320 0x515a 0x9c58 0x367 0x33b 0x534a 0x9be9 0x36b 0x33f 0x553a 0x9b5f 0x355 0x32a 0x572a 0x9aa4 0x2f7 0x2d1 0x5919 0x9a0f 0x2d7 0x2b3 0x5b09 0x99a7 0x2d5 0x2b1 0x5cf9 0x994a 0x2d5 0x2b1 0x5ee9 0x98f8 0x2bc 0x299 0x60d9 0x98a8 0x2bc 0x299 0x62c9 0x985f 0x2bc 0x299 0x64b9 0x9818 0x2bc 0x299 0x66a9 0x97d1 0x2ba 0x297 0x6898 0x9794 0x2a5 0x283 0x6a88 0x9757 0x2bc 0x299 0x6c78 0x971a 0x2bc 0x299 0x6e68 0x96de 0x2bc 0x299 0x7058 0x96ab 0x2c1 0x29e 0x7248 0x9676 0x2d0 0x2ac 0x7438 0x963b 0x2bc 0x299 0x7627 0x960a 0x2c2 0x29f 0x7817 0x95df 0x2d5 0x2b1 0x7a07 0x95ac 0x2d5 0x2b1 0x7bf7 0x957c 0x2d5 0x2b1 0x7de7 0x9553 0x2d5 0x2b1 0x7fd7 0x952a 0x2de 0x2b9 0x81c7 0x9502 0x2ee 0x2c9 0x83b6 0x94dc 0x301 0x2db 0x85a6 0x94ba 0x320 0x2f8 0x8796 0x9489 0x316 0x2ef 0x8986 0x9443 0x2f1 0x2cb 0x8b76 0x93e8 0x2be 0x29b 0x8d66 0x9390 0x2a3 0x281 0x8f56 0x934e 0x2af 0x28d 0x9145 0x9316 0x2bc 0x299 0x9335